# Скопируйте в /etc/chadow/env (или /etc/chadow/clan-reserves.env).
# Обычно достаточно обновить код и нажать «Обновить» на странице резервов —
# ключ шифрования сохранится в БД (site_settings.clan_reserve_token_key).
#
# Дополнительно нужно только если PHP-FPM использует переменные окружения,
# которых нет в админке сайта (другой WG_APPLICATION_ID и т.п.):
#
# WG_APPLICATION_ID=...
# LESTA_APPLICATION_ID=...
# GAME_TOKEN_ENC_KEY=base64_encoded_32_byte_key
